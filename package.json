    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.8.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^3.2.3"
  }
